<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TelleWork Workflow</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { font-family: 'Segoe UI', 'Traditional Arabic', Tahoma, sans-serif; background: linear-gradient(180deg, #f0fdf4 0%, #f8fafc 100%); min-height: 100vh; }
        .navbar { background: linear-gradient(90deg, #32b380 0%, #1e7d4a 100%)!important; box-shadow: 0 4px 16px rgba(0,0,0,0.12); }
        .navbar .nav-link { color: rgba(255,255,255,0.95)!important; font-weight: 500; padding: 10px 16px!important; border-radius: 8px; }
        .navbar .nav-link:hover { color: #fff!important; background: rgba(255,255,255,0.15); }
        .navbar-brand { color: #fff!important; font-weight: bold; }
        .navbar-brand img { height: 48px; margin-left: 10px; border-radius: 8px; }
        .card { border-radius: 14px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); border: none; }
        .btn-primary { background: linear-gradient(135deg, #32b380 0%, #1e7d4a 100%); border: none; padding: 10px 20px; border-radius: 10px; }
        .btn-primary:hover { background: linear-gradient(135deg, #2a9d6e 0%, #166534 100%); transform: translateY(-1px); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-0 box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="~/images/TELLEWORK.jpg" alt="TelleWork" onerror="this.src='https://i.ibb.co/NynTy6Q/xtra-wafek-logo.png'" />
                    TelleWork Workflow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/WorkflowMaster">مصمم الورك فلو</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/WorkflowReview" asp-route-id="1">مراجعة الورك فلو</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/EmailCommands" style="color:#fef08a!important">الأوامر السحرية (*#)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Setup">الإعدادات</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Wafek_Web_Manager - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>