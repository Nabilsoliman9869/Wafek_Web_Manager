@page
@model Wafek_Web_Manager.Pages.WorkflowCreateModel
@{
    ViewData["Title"] = "Create New Workflow";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h4>✨ Create New Workflow</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Workflow Name</label>
                    <input asp-for="Workflow.Name" class="form-control" placeholder="e.g. Purchase Approval > 5000" required />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Workflow.Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Source Table (Type)</label>
                        <select asp-for="Workflow.SourceTable" class="form-select" id="sourceTableSelect" onchange="toggleDocTypes()">
                            <option value="">-- Select Source --</option>
                            <option value="TBL009">TBL009 (Bonds/Sanadat)</option>
                            <option value="TBL020">TBL020 (Invoices/Fawateer)</option>
                            <option value="TBL085">TBL085 (Archive)</option>
                        </select>
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Specific Document Type</label>
                        <!-- Hidden Input to store the selected Guid -->
                        <input type="hidden" asp-for="Workflow.SpecificDocTypeGuid" id="selectedDocTypeGuid" />
                        
                        <!-- Bond Types Dropdown -->
                        <select id="bondTypes" class="form-select doc-type-select" style="display:none;" onchange="updateGuid(this)">
                            <option value="">-- Select Bond Type --</option>
                            @foreach (var item in Model.BondTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>

                        <!-- Invoice Types Dropdown -->
                        <select id="invoiceTypes" class="form-select doc-type-select" style="display:none;" onchange="updateGuid(this)">
                            <option value="">-- Select Invoice Type --</option>
                            @foreach (var item in Model.InvoiceTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>

                        <!-- Archive Types Dropdown -->
                        <select id="archiveTypes" class="form-select doc-type-select" style="display:none;" onchange="updateGuid(this)">
                            <option value="">-- Select Archive Type --</option>
                            @foreach (var item in Model.ArchiveTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Trigger Event</label>
                    <select asp-for="Workflow.TriggerEvent" class="form-select">
                        <option value="OnAfterInsert">On After Insert (New Record)</option>
                        <option value="OnBeforeInsert">On Before Insert</option>
                        <option value="OnUpdate">On Update (Modification)</option>
                        <option value="OnDelete">On Delete</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Condition (SQL WHERE Clause)</label>
                    <input asp-for="Workflow.ConditionSql" class="form-control" placeholder="e.g. NetTotal > 5000 AND BranchID = 1" />
                    <div class="form-text">Leave empty to run for all records. Use SQL syntax.</div>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Workflow.IsActive" class="form-check-input" type="checkbox" checked />
                    <label class="form-check-label">Active</label>
                </div>

                <button type="submit" class="btn btn-primary">Create Workflow</button>
                <a asp-page="./WorkflowDesigner" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleDocTypes() {
        var source = document.getElementById("sourceTableSelect").value;
        var bondSelect = document.getElementById("bondTypes");
        var invoiceSelect = document.getElementById("invoiceTypes");
        var archiveSelect = document.getElementById("archiveTypes");
        
        // Hide all first
        bondSelect.style.display = "none";
        invoiceSelect.style.display = "none";
        archiveSelect.style.display = "none";
        
        // Reset Guid
        document.getElementById("selectedDocTypeGuid").value = "";
        bondSelect.value = "";
        invoiceSelect.value = "";
        archiveSelect.value = "";

        if (source === "TBL009") {
            bondSelect.style.display = "block";
        } else if (source === "TBL020") {
            invoiceSelect.style.display = "block";
        } else if (source === "TBL085") {
            archiveSelect.style.display = "block";
        }
    }

    function updateGuid(selectElement) {
        document.getElementById("selectedDocTypeGuid").value = selectElement.value;
    }
</script>
