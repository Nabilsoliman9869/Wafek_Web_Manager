@page "/ApproveRequest/{id:long?}"
@model Wafek_Web_Manager.Pages.ApproveRequestModel
@{
    ViewData["Title"] = "طلب موافقة";
    Layout = null;
    var hasDocument = Model.Request != null && !string.IsNullOrEmpty(Model.Request.BondPrintHtml);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>طلب موافقة | نظام وافق</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; padding: 24px; background: linear-gradient(160deg, #1a2f24 0%, #2d5a45 30%, #e8f5e9 100%); font-family: 'Segoe UI', 'Traditional Arabic', Tahoma, sans-serif; min-height: 100vh; }
        .card { max-width: 720px; margin: 0 auto; background: #fff; border-radius: 20px; overflow: hidden; box-shadow: 0 12px 48px rgba(0,0,0,0.15); border: none; }
        .card-header { background: linear-gradient(135deg, #32b380 0%, #1e7d4a 100%); color: #fff; padding: 24px 28px; font-size: 22px; font-weight: bold; text-align: center; letter-spacing: 0.5px; }
        .card-body { padding: 28px; }
        .card-body p { margin: 12px 0; font-size: 15px; color: #333; }
        .btn-wrap { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 24px; }
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 16px 28px; font-size: 17px; font-weight: bold; border: none; border-radius: 14px; cursor: pointer; transition: all 0.25s ease; box-shadow: 0 4px 14px rgba(0,0,0,0.12); }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.18); }
        .btn:active { transform: translateY(-1px); }
        .btn-option { min-width: 140px; justify-content: center; }
        .btn-option.btn-save { background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); color: #fff!important; }
        .btn-option[data-value="Rejected"] { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: #fff!important; }
        .btn-option[data-value="Postponed"] { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #fff!important; }
        .btn-confirm { background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); color: #fff!important; padding: 18px 36px; font-size: 18px; }
        .btn-show-card { background: linear-gradient(135deg, #64748b 0%, #475569 100%); color: #fff!important; }
        .logo-wrap { width: 100%; background: linear-gradient(180deg, #f8faf8 0%, #fff 100%); overflow: hidden; padding: 20px; text-align: center; }
        .logo-wrap img { max-width: 280px; height: auto; display: block; margin: 0 auto; }
        .alert { padding: 16px 20px; border-radius: 12px; margin-top: 20px; font-size: 15px; }
        .alert-success { background: #dcfce7; color: #166534; border: 1px solid #22c55e; }
        .alert-danger { background: #fee2e2; color: #991b1b; border: 1px solid #ef4444; }
        .alert-info { background: #e0f2fe; color: #0369a1; border: 1px solid #0ea5e9; }
        hr { border: none; border-top: 2px solid #e5e7eb; margin: 24px 0; }
        .doc-block { margin: 20px 0; padding: 20px; background: #fafafa; border: 1px solid #e0e0e0; border-radius: 12px; }
        .selection-label { font-size: 14px; color: #64748b; margin-top: 12px; }
        .no-print { }
        @@media print {
            .no-print { display: none !important; }
            body { background: #fff; padding: 0; }
            .card { box-shadow: none; border: 1px solid #333; }
        }
    </style>
</head>
<body>
    @if (Model.Request == null)
    {
        <div class="alert @(Model.LogId == 0 ? "alert-info" : "alert-danger")" style="max-width:560px;margin:20px auto;padding:20px">
            @if (Model.LogId == 0)
            {
                <strong>أدخل رقم الطلب في الرابط</strong><br/>
                <span>مثال: <code>@("http://localhost:5246/ApproveRequest/123")</code></span><br/>
                <small>رقم الطلب (123) يأتي من رابط الميل الذي أُرسل إليك.</small>
            }
            else
            {
                <span>لم يتم العثور على الطلب رقم @Model.LogId.</span>
            }
        </div>
    }
    else
    {
        <div class="card">
            <div class="logo-wrap">
                <img src="@Url.Content("~/images/TELLEWORK.jpg")" alt="Logo" onerror="this.src='https://i.ibb.co/NynTy6Q/xtra-wafek-logo.png'" />
            </div>
            <div class="card-header">طلب موافقة | نظام وافق</div>
            <div class="card-body">
                <p><strong>رقم العملية:</strong> @Model.LogId</p>
                <p><strong>إلى السيد:</strong> @Model.RecipientName</p>
                <p><strong>نوع البطاقة (المصدر):</strong> @Model.Request.CardName</p>
                <p><strong>رقم البطاقة:</strong> @Model.Request.CardNumber</p>
                @if (!string.IsNullOrEmpty(Model.Request.BondDate)) { <p><strong>تاريخ السند:</strong> @Model.Request.BondDate</p> }
                <p><strong>المرسل:</strong> @Model.Request.SenderName</p>
                <p><strong>شركة:</strong> @Model.Request.CompanyName</p>
                <p><strong>هاتف:</strong> @Model.Request.CompanyPhone</p>
                <p><strong>ملاحظات الطلب:</strong> @Model.Request.Notes</p>

                @if (hasDocument)
                {
                    <hr/>
                    <div class="doc-block" id="document-print-area">
                        <div class="bond-print-block">@Html.Raw(Model.Request!.BondPrintHtml)</div>
                    </div>
                }

                <hr class="no-print"/>

                <div class="no-print">
                    <p style="font-weight:bold;margin-bottom:12px;font-size:16px">اختر أحد الخيارات ثم اضغط تأكيد:</p>
                    <form method="post" asp-page-handler="Save" id="approval-form">
                        <input type="hidden" name="logId" value="@Model.LogId" />
                        <input type="hidden" name="state" id="state-input" value="" />
                        <div class="btn-wrap" style="justify-content:flex-start;gap:12px;flex-direction:column;align-items:flex-start">
                            <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center">
                                <button type="button" class="btn btn-option btn-save" data-value="Approved" onclick="selectOption(this,'Approved')">✓ 1 موافق</button>
                                <button type="button" class="btn btn-option" data-value="Rejected" onclick="selectOption(this,'Rejected')">✗ 2 غير موفق</button>
                                <button type="button" class="btn btn-option" data-value="Postponed" onclick="selectOption(this,'Postponed')">⏳ 3 يؤجل</button>
                            </div>
                            <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;margin-top:16px">
                                <button type="submit" class="btn btn-confirm" id="btn-confirm" disabled>
                                    ✓ تأكيد الإرسال
                                </button>
                                @if (hasDocument)
                                {
                                    <button type="button" onclick="window.print()" class="btn btn-show-card">🖨️ طباعة</button>
                                }
                            </div>
                        </div>
                    </form>
                    <p id="selection-hint" style="font-size:13px;color:#666;margin-top:8px;display:none">تم اختيار: <strong id="selection-text"></strong></p>
                    <script>
                        function selectOption(btn, value) {
                            document.querySelectorAll('.btn-option').forEach(function(b) {
                                b.classList.remove('selected');
                                b.style.boxShadow = '';
                            });
                            btn.classList.add('selected');
                            btn.style.boxShadow = '0 0 0 4px #32b380';
                            document.getElementById('state-input').value = value;
                            document.getElementById('btn-confirm').disabled = false;
                            var texts = { Approved: 'موافق', Rejected: 'غير موفق', Postponed: 'يؤجل' };
                            document.getElementById('selection-text').textContent = texts[value];
                            document.getElementById('selection-hint').style.display = 'block';
                        }
                    </script>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")">@Model.Message</div>
                }
            </div>
        </div>
    }
</body>
</html>
